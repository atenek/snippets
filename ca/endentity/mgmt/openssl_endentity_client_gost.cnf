# End Entity (ГОСТ) OpenSSL config file — КЛИЕНТСКИЙ сертификат (GOST-TLS client / пользователь)
# Плейсхолдеры @@...@@ подставляются скриптом endentity_init.py (без sed):
#   @@CA_DIR@@       — каталог хранилища конечных сертификатов (gost-дерево)
#   @@SIGNING_KEY@@  — приватный ключ выбранного промежуточного CA
#   @@SIGNING_CERT@@ — сертификат выбранного промежуточного CA
#   @@CN@@           — имя сертификата (CN) из параметра --cn
#   @@MD@@           — digest подписи из криптопрофиля (md_gost12_256 / md_gost12_512)
# Регистрация gost-engine — через окружение OPENSSL_CONF/ENGINES/MODULES
# (выставляет lib/ca_lib.py, см. gost_env), в самом конфиге её нет.

[ ca ]
default_ca = ee_ca

[ ee_ca ]
# Directory and file locations.
dir               = @@CA_DIR@@
certs             = $dir/certs
crl_dir           = $dir/crl
new_certs_dir     = $dir/newcerts
database          = $dir/index.txt
serial            = $dir/serial
RANDFILE          = $dir/private/.rand

# Ключ и сертификат ПОДПИСЫВАЮЩЕГО (промежуточного) CA.
private_key       = @@SIGNING_KEY@@
certificate       = @@SIGNING_CERT@@

# For certificate revocation lists.
crlnumber         = $dir/crlnumber
crl               = $dir/crl/ee.crl.pem
crl_extensions    = crl_ext
default_crl_days  = 30

default_md        = @@MD@@

name_opt          = ca_default
cert_opt          = ca_default
default_days      = 365
preserve          = no
policy            = policy_endentity

[ policy_endentity ]
# See the POLICY FORMAT section of the `ca` man page.
countryName             = match
stateOrProvinceName     = optional
organizationName        = optional
organizationalUnitName  = optional
commonName              = supplied
emailAddress            = optional

[ req ]
# Options for the `req` tool (`man req`).
# prompt = no — DN берётся из конфига без интерактивного диалога openssl.
# Поля при необходимости правятся в редакторе (vim) на шаге проверки конфига.
prompt              = no
distinguished_name  = req_distinguished_name
string_mask         = utf8only
default_md          = @@MD@@

[ req_distinguished_name ]
# See https://en.wikipedia.org/wiki/Certificate_signing_request.
countryName            = ru
stateOrProvinceName    = Moscow
localityName           = Moscow
organizationName       = LBOSSE Corporation Ltd
organizationalUnitName = LBOSSE QA Department
commonName             = @@CN@@
emailAddress           = hc@lbosse.ru

[ x509_ext_ee ]
# Extensions for CLIENT certificates (`man x509v3_config`).
basicConstraints = CA:FALSE
nsComment = "Client certificate for LBOSSE Corporation Ltd internal use only"
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid,issuer:always
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = clientAuth
subjectAltName = @alt_names

[ alt_names ]
# Идентификаторы владельца клиентского сертификата (обычно e-mail).
email.1 = hc@lbosse.ru
email.2 = health-check@lbosse.com

[ crl_ext ]
# Extension for CRLs (`man x509v3_config`).
authorityKeyIdentifier=keyid:always

[ ocsp ]
# Extension for OCSP signing certificates (`man ocsp`).
basicConstraints = CA:FALSE
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid,issuer
keyUsage = critical, digitalSignature
extendedKeyUsage = critical, OCSPSigning

    },
    {
      "name": "lb_bgp",
      "ip": "127.0.0.1",
      "port": 8731,
      "path": "/bgp"
    },
    {
      "name": "lb_plain",
      "ip": "127.0.0.1",
      "port": 8731,
      "path": "/plain"
    }
  ]
